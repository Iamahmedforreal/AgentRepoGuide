// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  USER
  ADMIN
  PRO
}
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}
enum RepoStatus {
   PENDING
  VALIDATING
  REJECTED
  PROCESSING
  READY
  FAILED
}


enum JobStatus{
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}
enum FileStatus {
  PENDING       // file discovered, not yet processed
  PROCESSING    // currently being chunked/embedded
  EMBEDDED      // vectors stored, ready for RAG
  SKIPPED       // ignored (binary, too large, irrelevant type)
  FAILED        // something went wrong
}
//models
model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique  // Clerk's user ID (user_xxx)
  
  email           String?   @unique
  firstName       String?
  lastName        String?
  username        String?   @unique
  profileImageUrl String?
  
  // Account Status
  banned        Boolean   @default(false)
  deletedAt     DateTime? // Soft delete timestamp
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLoginAt DateTime?

  repositories Repository[]


  @@index([clerkId])
  @@index([email])
  @@index([deletedAt]) // For filtering active users
}

model Repository {
  id            String      @id @default(cuid())  
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  githubUrl     String
  repoName      String?
  repoOwner     String?
  defaultBranch String?
  isPrivate     Boolean     @default(false)
  sizeKb        Int?
  description   String?     
  language      String?     
  topics        String[]    
  stars         Int?        
  license       String?     
  isArchived    Boolean     @default(false) 
  repoCreatedAt DateTime?   
  repoUpdatedAt DateTime?   
  status        RepoStatus  @default(PENDING)
  localPath     String?     // absolute path on disk where the repo was cloned
  ingestionJobs IngestionJob[]
  files         RepoFile[]
  createdAt     DateTime    @default(now())  
  updatedAt     DateTime    @updatedAt       
  @@unique([userId, githubUrl])  
  @@index([userId])              
  @@index([language])             
  @@index([status])               
}
model IngestionJob {
  id            String    @id @default(cuid())

  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id])

  status        JobStatus @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?

  createdAt     DateTime  @default(now())
}

model RepoFile {
  id              String      @id @default(cuid())

  // ─── Relationship ───────────────────────────────────────
  repositoryId    String
  repository      Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  // ─── File Identity ──────────────────────────────────────
  filePath        String      // "src/lib/auth/jwt.js"
  fileName        String      // "jwt.js"
  extension       String?     // "js" — for filtering by type
  language        String?     // "JavaScript" — detected by GitHub API

  // ─── Content ────────────────────────────────────────────
  rawContent      String?     @db.Text   // full file content (nullable — fetch on demand)
  contentHash     String?     // SHA of content — detect if file changed on re-ingestion
  sizeBytes       Int?        // guard: skip files over your limit (e.g. 500kb)
  lineCount       Int?        // useful for chunking decisions

  // ─── RAG Signals ────────────────────────────────────────
  isEntryPoint    Boolean     @default(false)  // index.js, main.py — boost in ranking
  isTest          Boolean     @default(false)  // test files — optionally exclude from RAG
  isGenerated     Boolean     @default(false)  // dist/, build/ — usually skip these

  // ─── Pipeline State ─────────────────────────────────────
  status          FileStatus  @default(PENDING)
  skippedReason   String?     // why it was skipped e.g. "binary file", "too large"
 

  // ─── Timestamps ─────────────────────────────────────────
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // ─── Indexes ────────────────────────────────────────────
  @@unique([repositoryId, filePath])   // same file can't be stored twice per repo
  @@index([repositoryId])
  @@index([status])                    // worker queries: WHERE status = PENDING
  @@index([language])                  // RAG pre-filter by language
  @@index([extension])                 // quickly find all .md or .ts files
}

model WebhookEvent {
  id          String   @id @default(cuid())
  clerkId     String @unique
  type        String
  payload     Json
  createdAt   DateTime @default(now())
}